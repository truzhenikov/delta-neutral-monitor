APP_ENV=dev
API_HOST=0.0.0.0
API_PORT=8080
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

USE_MOCK_DATA=true
REQUEST_TIMEOUT_SEC=10
ALERT_POLL_INTERVAL_SEC=30
ALERT_COOLDOWN_SEC=300

# Comma-separated: bitget,bingx,mexc,hyperliquid,extended,okx,kucoin,aden
ENABLED_EXCHANGES=bitget,bingx,mexc,hyperliquid,extended,okx,kucoin,aden

# Bitget
BITGET_API_BASE=https://api.bitget.com
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=
BITGET_PRODUCT_TYPE=USDT-FUTURES
BITGET_MARGIN_COIN=USDT

# BingX Futures
BINGX_API_BASE=https://open-api.bingx.com
BINGX_API_KEY=
BINGX_API_SECRET=

# OKX
# Region-specific base might differ (e.g. https://us.okx.com for some accounts)
OKX_API_BASE=https://www.okx.com
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=

# Hyperliquid
HYPERLIQUID_API_BASE=https://api.hyperliquid.xyz
HYPERLIQUID_USER_ADDRESS=
HYPERLIQUID_DEX=
HYPERLIQUID_PRIVATE_KEY=
HYPERLIQUID_READ_ONLY=true

# Extended
EXTENDED_API_BASE=https://api.starknet.extended.exchange
EXTENDED_API_KEY=
EXTENDED_STARK_KEY_PUBLIC=
EXTENDED_STARK_KEY_PRIVATE=
EXTENDED_VAULT_NUMBER=
EXTENDED_CLIENT_ID=
EXTENDED_READ_ONLY=true

# KuCoin Futures
KUCOIN_API_BASE=https://api-futures.kucoin.com
KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_API_PASSPHRASE=

# ADEN.IO Perps
ADEN_API_BASE=https://api.aden.io
ADEN_API_PREFIX=/api/v1
ADEN_API_KEY=
ADEN_API_SECRET=

# Alert thresholds
MAX_MARGIN_RATIO=0.75
MIN_LIQ_DISTANCE_PCT=12
MAX_ABS_NET_DELTA_USD=500
