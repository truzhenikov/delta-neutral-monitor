[Unit]
Description=Delta Neutral Monitor FastAPI backend
After=network.target

[Service]
Type=simple
WorkingDirectory=/root/projects/delta-neutral-monitor
Environment=APP_ENV=prod
Environment=USE_MOCK_DATA=false
Environment=ENABLED_EXCHANGES=bitget,bingx,hyperliquid,extended,okx,kucoin
Environment=REQUEST_TIMEOUT_SEC=20
ExecStart=/usr/local/lib/hermes-agent/venv/bin/python3 -m uvicorn src.main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
